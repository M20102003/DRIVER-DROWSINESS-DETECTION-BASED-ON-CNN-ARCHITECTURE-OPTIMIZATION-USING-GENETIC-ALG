<svg viewBox="0 0 800 720" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect x="0" y="0" width="800" height="720" fill="#f8f9fa" rx="10" ry="10"/>
  
  <!-- Title -->
  <text x="400" y="40" font-family="Arial" font-size="24" text-anchor="middle" font-weight="bold">Advanced CNN Architecture Visualizations</text>
  
  <!-- 1. CODE REPRESENTATION -->
  <text x="400" y="80" font-family="Arial" font-size="18" text-anchor="middle" font-weight="bold">Python/TensorFlow Implementation</text>
  
  <!-- Code box -->
  <rect x="100" y="95" width="600" height="145" fill="#f1f3f5" stroke="#ced4da" stroke-width="1" rx="5" ry="5"/>
  <text x="110" y="115" font-family="Courier New" font-size="12" text-anchor="start">import tensorflow as tf</text>
  <text x="110" y="135" font-family="Courier New" font-size="12" text-anchor="start">def create_model(input_shape=(None, None, 3)):</text>
  <text x="110" y="155" font-family="Courier New" font-size="12" text-anchor="start">    model = tf.keras.Sequential([</text>
  <text x="110" y="175" font-family="Courier New" font-size="12" text-anchor="start">        tf.keras.layers.Conv2D(32, (3, 3), activation='relu', input_shape=input_shape),</text>
  <text x="110" y="195" font-family="Courier New" font-size="12" text-anchor="start">        tf.keras.layers.Conv2D(128, (3, 3), activation='relu'),</text>
  <text x="110" y="215" font-family="Courier New" font-size="12" text-anchor="start">        tf.keras.layers.Conv2D(128, (5, 5), activation='relu'),</text>
  <text x="110" y="235" font-family="Courier New" font-size="12" text-anchor="start">        tf.keras.layers.Dense(256, activation='relu'),</text>
  <text x="110" y="255" font-family="Courier New" font-size="12" text-anchor="start">        tf.keras.layers.Dropout(0.3)</text>
  <text x="110" y="275" font-family="Courier New" font-size="12" text-anchor="start">    ])</text>
  <text x="110" y="295" font-family="Courier New" font-size="12" text-anchor="start">    return model</text>
  
